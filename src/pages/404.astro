---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Not found — LuxeDate" description="Page not found.">
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-4">
      <div class="max-w-xl rounded-3xl border border-white/10 bg-white/5 p-10">
        <p class="text-xs font-semibold tracking-[0.18em] text-white/60">404</p>
        <h1 class="mt-3 text-3xl font-semibold">Page not found</h1>
        <p class="mt-3 text-white/70">The page you’re looking for doesn’t exist.</p>
        <div class="mt-6">
          <Button href="/" variant="primary" size="lg">Back home</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
