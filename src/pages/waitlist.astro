---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Waitlist — LuxeDate" description="Join the LuxeDate waitlist and request Telegram beta access." active="/waitlist">
  <Section eyebrow="WAITLIST" title="Join the LuxeDate waitlist" subtitle="Get AI-curated San Diego alerts for restaurants, events, and luxury travel—only when it’s worth your time.">
    <div class="grid gap-4 lg:grid-cols-12">
      <Card class="lg:col-span-7">
        <h2 class="text-base font-semibold">Get notified when access opens</h2>
        <p class="mt-2 text-sm text-white/70">This is a static beta form placeholder. Wire it to your backend later.</p>

        <form class="mt-6 space-y-4" method="post" action="#">
          <div>
            <label class="text-sm text-white/80" for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="you@domain.com" required class="mt-2 w-full rounded-xl border border-white/10 bg-ink-900/60 px-4 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-champagne-500/70" />
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="text-sm text-white/80" for="neighborhoods">Neighborhoods (optional)</label>
              <input id="neighborhoods" name="neighborhoods" type="text" placeholder="North Park, La Jolla" class="mt-2 w-full rounded-xl border border-white/10 bg-ink-900/60 px-4 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-champagne-500/70" />
            </div>
            <div>
              <label class="text-sm text-white/80" for="vibe">Vibe (optional)</label>
              <input id="vibe" name="vibe" type="text" placeholder="romantic, lively, low-key" class="mt-2 w-full rounded-xl border border-white/10 bg-ink-900/60 px-4 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-champagne-500/70" />
            </div>
          </div>

          <div>
            <label class="text-sm text-white/80" for="budget">Budget band (optional)</label>
            <select id="budget" name="budget" class="mt-2 w-full rounded-xl border border-white/10 bg-ink-900/60 px-4 py-3 text-sm text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-champagne-500/70">
              <option value="" selected>Select…</option>
              <option value="mid">Mid</option>
              <option value="high">High</option>
              <option value="splurge">Splurge</option>
            </select>
          </div>

          <p class="text-xs text-white/50">By joining, you agree to receive beta updates. Unsubscribe anytime.</p>

          <div class="flex flex-col gap-2 sm:flex-row">
            <Button variant="primary" size="lg" type="submit">Get LuxeDate alerts</Button>
            <Button href="#telegram" variant="teal" size="lg">Request Telegram beta</Button>
          </div>
        </form>
      </Card>

      <Card class="lg:col-span-5" >
        <h2 id="telegram" class="text-base font-semibold">Want alerts on Telegram?</h2>
        <p class="mt-2 text-sm text-white/70">Telegram is our fastest channel during beta.</p>
        <ol class="mt-5 list-decimal space-y-2 pl-5 text-sm text-white/75">
          <li>Join the waitlist</li>
          <li>Request Telegram beta</li>
          <li>We’ll send you the bot link when a slot opens</li>
        </ol>
        <div class="mt-6 flex flex-col gap-2">
          <Button href="#" variant="teal" size="lg">Request Telegram beta</Button>
          <a class="text-sm text-white/60 hover:text-white" href="/privacy">Read privacy policy</a>
        </div>
      </Card>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <Card>
        <h3 class="text-base font-semibold">Low volume by design</h3>
        <p class="mt-2 text-sm text-white/70">If there’s nothing worth booking, you won’t hear from us.</p>
      </Card>
      <Card>
        <h3 class="text-base font-semibold">Action-first format</h3>
        <p class="mt-2 text-sm text-white/70">Short context, clear “why,” and a path to book.</p>
      </Card>
      <Card>
        <h3 class="text-base font-semibold">San Diego only (for now)</h3>
        <p class="mt-2 text-sm text-white/70">We’d rather do one city exceptionally well.</p>
      </Card>
    </div>
  </Section>
</BaseLayout>
