---
import Button from './Button.astro';
import Card from './Card.astro';

const {
  title = 'Get the next great spot before it’s gone.',
  subtitle = 'No spam. Few alerts. High signal.',
  primaryHref = '/waitlist',
  primaryText = 'Join the waitlist',
  secondaryHref = '/waitlist#telegram',
  secondaryText = 'Request Telegram beta'
} = Astro.props;
---
<div class="py-6">
  <Card class="bg-gradient-to-b from-white/7 to-white/4">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div>
        <h3 class="text-xl font-semibold tracking-tight">{title}</h3>
        <p class="mt-2 text-sm text-white/70">{subtitle}</p>
      </div>
      <div class="flex w-full flex-col gap-2 sm:flex-row md:w-auto">
        <Button href={primaryHref} variant="primary" size="lg">{primaryText}</Button>
        <Button href={secondaryHref} variant="teal" size="lg">{secondaryText}</Button>
      </div>
    </div>
  </Card>
</div>
