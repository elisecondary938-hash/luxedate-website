---
const { title, eyebrow, subtitle, id } = Astro.props;
---
<section id={id} class="py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-4">
    {(title || eyebrow || subtitle) && (
      <header class="mb-10 max-w-2xl">
        {eyebrow && <p class="text-xs font-semibold tracking-[0.18em] text-champagne-500/90">{eyebrow}</p>}
        {title && <h2 class="mt-3 text-2xl font-semibold tracking-tight md:text-3xl">{title}</h2>}
        {subtitle && <p class="mt-3 text-base text-white/70">{subtitle}</p>}
      </header>
    )}
    <slot />
  </div>
</section>
