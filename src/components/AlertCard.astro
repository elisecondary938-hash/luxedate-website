---
const { kind = 'Restaurant', title, meta, why = [], cta1 = 'Open', cta2 = 'Save' } = Astro.props;
---
<div class="rounded-2xl border border-white/10 bg-ink-800/60 p-5 backdrop-blur">
  <div class="flex items-center justify-between">
    <p class="text-xs font-semibold tracking-[0.18em] text-champagne-500/90">{kind.toUpperCase()}</p>
    <span class="text-[11px] text-white/50">Example</span>
  </div>
  <h3 class="mt-3 text-base font-semibold leading-snug">{title}</h3>
  {meta && <p class="mt-1 text-sm text-white/60">{meta}</p>}
  {why?.length ? (
    <ul class="mt-4 space-y-2 text-sm text-white/75">
      {why.map((w) => <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-white/40" /> <span>{w}</span></li>)}
    </ul>
  ) : null}
  <div class="mt-5 flex gap-2">
    <span class="inline-flex items-center rounded-lg border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-white/80">{cta1}</span>
    <span class="inline-flex items-center rounded-lg border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-white/80">{cta2}</span>
  </div>
</div>
